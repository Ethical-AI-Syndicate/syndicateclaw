# SyndicateClaw Environment Configuration
#
# Multiple environments can coexist on a single host:
#
#   Environment   Database                  Redis DB   API Port
#   ─────────────────────────────────────────────────────────────
#   dev           syndicateclaw_dev         1          8001
#   staging       syndicateclaw_staging     2          8002
#   prod          syndicateclaw_prod        3          8000
#
# Usage:
#   1. Copy this file to .env.dev, .env.staging, or .env.prod
#   2. Set SYNDICATECLAW_ENV=<env> before running the app or alembic
#   3. Or: source scripts/env.sh <env>
#
# The app loads .env.{SYNDICATECLAW_ENV} first, with .env as fallback.
# Alembic reads SYNDICATECLAW_DATABASE_URL from the environment.

# Core
SYNDICATECLAW_ENVIRONMENT=development
SYNDICATECLAW_SECRET_KEY=change-me-to-a-random-secret
SYNDICATECLAW_LOG_LEVEL=INFO

# Database (one DB per environment on the same PostgreSQL cluster)
SYNDICATECLAW_DATABASE_URL=postgresql+asyncpg://syndicateclaw:syndicateclaw@localhost:5432/syndicateclaw_dev

# Redis (one logical DB per environment on the same Redis instance)
SYNDICATECLAW_REDIS_URL=redis://localhost:6379/1

# API server
SYNDICATECLAW_API_HOST=0.0.0.0
SYNDICATECLAW_API_PORT=8001

# OpenTelemetry (optional)
# SYNDICATECLAW_OTEL_ENDPOINT=http://localhost:4317

# CORS (optional)
# SYNDICATECLAW_CORS_ORIGINS=["http://localhost:3000"]

# Auth
# SYNDICATECLAW_JWT_ALGORITHM=HS256
# SYNDICATECLAW_ED25519_PRIVATE_KEY_PATH=
# SYNDICATECLAW_REQUIRE_ASYMMETRIC_SIGNING=false
# SYNDICATECLAW_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
# SYNDICATECLAW_OIDC_ISSUER=https://accounts.google.com
# SYNDICATECLAW_JWT_AUDIENCE=

# Provider topology
# SYNDICATECLAW_PROVIDERS_YAML_PATH=/app/providers.syndicategate.yaml
# SYNDICATEGATE_API_KEY=sk-sg-...

# Rate limiting
# SYNDICATECLAW_RATE_LIMIT_REQUESTS=100
# SYNDICATECLAW_RATE_LIMIT_WINDOW_SECONDS=60
# SYNDICATECLAW_RATE_LIMIT_BURST=20
# SYNDICATECLAW_RATE_LIMIT_STRICT=false
