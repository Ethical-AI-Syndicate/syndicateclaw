{
  "$defs": {
    "ExecutionLimits": {
      "additionalProperties": false,
      "properties": {
        "max_memory_writes": {
          "default": 2,
          "minimum": 0,
          "title": "Max Memory Writes",
          "type": "integer"
        },
        "max_runtime_ms": {
          "default": 20000,
          "minimum": 1,
          "title": "Max Runtime Ms",
          "type": "integer"
        },
        "max_tool_calls": {
          "default": 5,
          "minimum": 0,
          "title": "Max Tool Calls",
          "type": "integer"
        }
      },
      "title": "ExecutionLimits",
      "type": "object"
    },
    "ExecutionMode": {
      "enum": [
        "single_step",
        "planned_step"
      ],
      "title": "ExecutionMode",
      "type": "string"
    },
    "PlanContext": {
      "additionalProperties": false,
      "properties": {
        "plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Plan Id"
        },
        "step_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step Id"
        },
        "step_number": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step Number"
        }
      },
      "title": "PlanContext",
      "type": "object"
    },
    "SkillRef": {
      "additionalProperties": false,
      "properties": {
        "skill_id": {
          "title": "Skill Id",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "skill_id",
        "version"
      ],
      "title": "SkillRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "execution_id": {
      "minLength": 1,
      "title": "Execution Id",
      "type": "string"
    },
    "execution_mode": {
      "$ref": "#/$defs/ExecutionMode",
      "default": "single_step"
    },
    "input_payload": {
      "additionalProperties": true,
      "title": "Input Payload",
      "type": "object"
    },
    "limits": {
      "$ref": "#/$defs/ExecutionLimits"
    },
    "plan_context": {
      "$ref": "#/$defs/PlanContext"
    },
    "skill": {
      "$ref": "#/$defs/SkillRef"
    },
    "task_id": {
      "minLength": 1,
      "title": "Task Id",
      "type": "string"
    }
  },
  "required": [
    "execution_id",
    "task_id",
    "skill"
  ],
  "title": "ExecutionRequest",
  "type": "object"
}
