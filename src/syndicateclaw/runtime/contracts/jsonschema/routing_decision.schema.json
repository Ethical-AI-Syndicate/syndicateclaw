{
  "$defs": {
    "RoutingStatus": {
      "enum": [
        "selected",
        "uncertain",
        "blocked"
      ],
      "title": "RoutingStatus",
      "type": "string"
    },
    "SelectedSkill": {
      "additionalProperties": false,
      "properties": {
        "skill_id": {
          "title": "Skill Id",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "skill_id",
        "version"
      ],
      "title": "SelectedSkill",
      "type": "object"
    },
    "SkillCandidate": {
      "additionalProperties": false,
      "properties": {
        "reason": {
          "items": {
            "type": "string"
          },
          "title": "Reason",
          "type": "array"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "skill_id": {
          "title": "Skill Id",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "skill_id",
        "version",
        "score"
      ],
      "title": "SkillCandidate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "candidates": {
      "items": {
        "$ref": "#/$defs/SkillCandidate"
      },
      "title": "Candidates",
      "type": "array"
    },
    "policy_notes": {
      "items": {
        "type": "string"
      },
      "title": "Policy Notes",
      "type": "array"
    },
    "routing_status": {
      "$ref": "#/$defs/RoutingStatus"
    },
    "selected_skill": {
      "anyOf": [
        {
          "$ref": "#/$defs/SelectedSkill"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "timestamp": {
      "title": "Timestamp",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "routing_status",
    "timestamp"
  ],
  "title": "RoutingDecision",
  "type": "object"
}
