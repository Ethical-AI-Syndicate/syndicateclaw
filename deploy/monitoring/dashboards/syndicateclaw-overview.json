{
  "dashboard": {
    "title": "SyndicateClaw Overview",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "targets": [{"expr": "sum(rate(syndicateclaw_http_requests_total[5m])) by (method)"}]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [{"expr": "sum(rate(syndicateclaw_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(syndicateclaw_http_requests_total[5m]))"}]
      },
      {
        "title": "p95 Latency",
        "type": "timeseries",
        "targets": [{"expr": "histogram_quantile(0.95, sum(rate(syndicateclaw_http_request_duration_seconds_bucket[5m])) by (le))"}]
      },
      {
        "title": "Workflow Runs",
        "type": "stat",
        "targets": [{"expr": "sum(syndicateclaw_workflow_runs_total) by (status)"}]
      },
      {
        "title": "Inference Latency by Provider",
        "type": "timeseries",
        "targets": [{"expr": "histogram_quantile(0.95, sum(rate(syndicateclaw_inference_duration_seconds_bucket[5m])) by (le, provider))"}]
      },
      {
        "title": "Dead Letter Queue Size",
        "type": "gauge",
        "targets": [{"expr": "syndicateclaw_dead_letter_queue_size"}]
      },
      {
        "title": "Policy Evaluations",
        "type": "piechart",
        "targets": [{"expr": "sum(syndicateclaw_policy_evaluations_total) by (result)"}]
      }
    ]
  }
}
